        },
        "age": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 0,
          "title": "Age"
        },
        "personality": {
          "items": {
            "type": "string"
          },
          "title": "Personality",
          "type": "array"
        },
        "background": {
          "items": {
            "type": "string"
          },
          "title": "Background",
          "type": "array"
        },
        "abilities": {
          "items": {
            "type": "string"
          },
          "title": "Abilities",
          "type": "array"
        },
        "limitations": {
          "items": {
            "type": "string"
          },
          "title": "Limitations",
          "type": "array"
        },
        "relationships": {
          "additionalProperties": true,
          "title": "Relationships",
          "type": "object"
        },
        "motivation": {
          "items": {
            "type": "string"
          },
          "title": "Motivation",
          "type": "array"
        },
        "key_memories": {
          "items": {
            "type": "string"
          },
          "title": "Key Memories",
          "type": "array"
        },
        "story_function": {
          "items": {
            "type": "string"
          },
          "title": "Story Function",
          "type": "array"
        },
        "beliefs": {
          "items": {
            "type": "string"
          },
          "title": "Beliefs",
          "type": "array"
        },
        "ambiguity": {
          "items": {
            "type": "string"
          },
          "title": "Ambiguity",
          "type": "array"
        },
        "identities": {
          "items": {
